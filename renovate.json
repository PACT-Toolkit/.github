{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dryRun": null,
  "schedule": ["before 9am on Monday"],
  "labels": ["dependencies"],
  "automerge": false,
  "packageRules": [
    {
      "description": "Group all Go dependencies into one PR",
      "matchManagers": ["gomod"],
      "groupName": "Go dependencies"
    },
    {
      "description": "Group all Python dependencies into one PR",
      "matchManagers": ["pip_requirements", "pipenv", "poetry"],
      "groupName": "Python dependencies"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Automerge patch-level Go updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Automerge minor and patch npm updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Group TypeScript type definitions",
      "matchPackagePatterns": ["^@types/"],
      "groupName": "TypeScript type definitions"
    },
    {
      "description": "Group linting tools",
      "matchPackageNames": ["eslint", "prettier"],
      "matchPackagePrefixes": ["@typescript-eslint/", "@eslint/"],
      "groupName": "Linting tools"
    }
  ]
}
